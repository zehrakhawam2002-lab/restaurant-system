# ════════════════════════════════════════
#  .env.example — نسخ لـ .env وعدّل القيم
#  لا ترفع الـ .env على GitHub أبداً!
# ════════════════════════════════════════

NODE_ENV=production
PORT=4000

# ── DATABASE
DATABASE_URL=postgresql://postgres@localhost:5432/restaurant_os
NODE_ENV=development
PORT=4000
JWT_SECRET=abcdefghijklmnopqrstuvwxyz123456789abcdefghijklmnopqrstuvwxyz12
JWT_REFRESH_SECRET=zyxwvutsrqponmlkjihgfedcba987654321zyxwvutsrqponmlkjihgfedcba
# ── CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://pos.yourdomain.com

# ── REDIS (للـ session cache و queue)
REDIS_URL=redis://:REDIS_PASSWORD@localhost:6379

# ── FILE STORAGE (Backblaze B2 أو AWS S3)
S3_BUCKET=restaurant-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your_key
S3_SECRET_KEY=your_secret

# ── SMS (Twilio)
TWILIO_SID=your_sid
TWILIO_TOKEN=your_token
TWILIO_FROM=+1234567890

# ── EMAIL (للتقارير والتنبيهات)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@restaurant.iq
SMTP_PASS=your_smtp_password
